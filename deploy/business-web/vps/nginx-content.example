# Replace with the VPS-facing domain that should front the isolated content instance.
# Example: ops.example.com
server {
  listen 80;
  listen [::]:80;
  server_name ops.example.com;

  return 301 https://$host$request_uri;
}

server {
  listen 443 ssl http2;
  listen [::]:443 ssl http2;
  server_name ops.example.com;

  ssl_certificate /etc/letsencrypt/live/ops.example.com/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/ops.example.com/privkey.pem;

  client_max_body_size 2m;

  location /openclaw/ {
    proxy_pass http://127.0.0.1:19889;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
  }

  location = /api/subscribe {
    proxy_pass http://127.0.0.1:19889/hooks/subscribe;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Authorization "Bearer REPLACE_WITH_OPENCLAW_HOOKS_TOKEN";
  }

  location = /healthz {
    proxy_pass http://127.0.0.1:19889/healthz;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }
}
